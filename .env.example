# ============================================================
# Neura Lead Demo Bot — пример переменных окружения
# Скопируйте в .env и заполните свои значения
# ============================================================

# --- ОБЯЗАТЕЛЬНО ---
BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff-xxxxxxxxx

# --- УВЕДОМЛЕНИЯ О ЛИДАХ ---
# ID чата/канала, куда приходят лиды (узнать: @userinfobot)
ADMIN_CHAT_ID=123456789

# --- LLM: OpenRouter (основной мозг, бесплатные модели) ---
# Ключ: openrouter.ai → Keys
DEEPSEEK_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Модели через запятую (каскад: первая упёрлась — берёт следующую)
LLM_MODELS=deepseek/deepseek-chat-v3-0324:free,qwen/qwen3-235b-a22b:free,meta-llama/llama-4-scout:free
LLM_BASE_URL=https://openrouter.ai/api/v1

# --- LLM: YandexGPT (страховка, опционально) ---
# Ключ: console.cloud.yandex.ru → API-ключи
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt-lite/latest

# --- LLM: GigaChat (опционально) ---
# Ключ: developers.sber.ru → GigaChat API
GIGACHAT_AUTH_KEY=
GIGACHAT_MODEL=GigaChat

# --- ДЕПЛОЙ ---
# Для webhook (Render/Railway/VPS) — укажите публичный URL вашего сервиса
# Для polling (Bothost) — оставьте пустым
WEBHOOK_URL=
PORT=8080
